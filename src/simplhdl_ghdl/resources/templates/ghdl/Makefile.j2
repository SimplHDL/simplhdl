# Generated by SimplHDL

GHDL := ghdl
GHDL_IMP := ghdl -i
GHDL_ELAB := ghdl -m
GHDL_RUN := ghdl -r

LIB_DIR := .
WAVES := --vcd=waves.vcd


TOP := {{cocotbdut}}

-include cocotb.mk
-include sources.mk

BUILD_DIR := stamps
STAMPS := $(addprefix $(BUILD_DIR)/, $(notdir $(SRCS:=.done)))

.PHONY: all simulate clean

all: simulate

# 1. The One-Rule-Per-File (The "Analysis" Phase)
# This rule matches any .done file in the build directory
$(BUILD_DIR)/%.done:
	@mkdir -p $(BUILD_DIR)
	@# Find the original source path by matching the filename
	$(eval SOURCE_PATH := $(filter %$*, $(SRCS)))
	$(GHDL) -i --workdir=$(BUILD_DIR) --work=$(LIB) $(SOURCE_PATH)
	@touch $@

# 2. Elaboration (The "Link" Phase)
elaborate: $(STAMPS)
	$(GHDL) -m --workdir=$(BUILD_DIR) -P$(BUILD_DIR) $(TOP)

# 3. Simulation (The "Run" Phase)
simulate: elaborate
	$(GHDL) -r --workdir=$(BUILD_DIR) -P$(BUILD_DIR) $(TOP) $(VPI)




